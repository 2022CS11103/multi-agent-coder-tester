# Free Groq API key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_real_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Max number of coder<->tester fix-it loops before giving up
MAX_ITERATIONS=3

# Docker image used to run generated code safely (sandboxed)
SANDBOX_IMAGE=python:3.11-slim

# Seconds before a code execution is killed (prevents infinite loops)
EXECUTION_TIMEOUT=15
